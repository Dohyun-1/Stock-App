{
  "name": "stock-hackathon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "simulator": "open -a Simulator && sleep 6 && xcrun simctl openurl booted http://localhost:3008",
    "clean": "rm -rf .next",
    "build": "next build",
    "rebuild": "rm -rf .next && next build",
